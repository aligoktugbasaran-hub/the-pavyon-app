generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String       @id @default(uuid())
  email         String?      @unique
  nickname      String       @unique
  avatar        String?      // Profile avatar URL or Base64
  gender        String?
  credits       Int          @default(100)
  earnings      Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt @default(now())
  messages      Message[]
  giftsGiven    Gift[]       @relation("GiftSender")
  giftsReceived Gift[]       @relation("GiftReceiver")
  
  // Friends & Blocking
  friendsSent      Friendship[] @relation("FriendSender")
  friendsReceived  Friendship[] @relation("FriendReceiver")
  blockedByMe      Block[]      @relation("Blocker")
  blockedMe        Block[]      @relation("Blocked")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  tableId   Int?     // null = global chat, number = table room
  roomType  String   @default("global") // "global" | "table"
  senderNickname String @default("")
  senderAvatar   String @default("")
  createdAt DateTime @default(now())
}

model Gift {
  id          String   @id @default(uuid())
  type        String   // "ROSE", "CHAMPAGNE", etc.
  creditCost  Int
  tlValue     Float
  senderId    String
  sender      User     @relation("GiftSender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("GiftReceiver", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())
}

model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("FriendSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("FriendReceiver", fields: [receiverId], references: [id])
  status     String   @default("PENDING") // PENDING, ACCEPTED
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id])
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}
