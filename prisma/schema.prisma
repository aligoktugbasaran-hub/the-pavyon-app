generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(uuid())
  email         String?      @unique
  nickname      String       @unique
  photos        String[]     // max 2 URL
  gender        String?
  credits       Int          @default(100)
  earnings      Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt @default(now())
  messages      Message[]
  giftsGiven    Gift[]       @relation("GiftSender")
  giftsReceived Gift[]       @relation("GiftReceiver")
  
  // Friends & Blocking
  friendsSent      Friendship[] @relation("FriendSender")
  friendsReceived  Friendship[] @relation("FriendReceiver")
  blockedByMe      Block[]      @relation("Blocker")
  blockedMe        Block[]      @relation("Blocked")
}

model Room {
  id        String    @id @default(uuid())
  name      String
  capacity  Int       @default(10)
  messages  Message[]
  isPrivate Boolean   @default(false)
  ownerId   String?
  createdAt DateTime  @default(now())
}

model Message {
  id        String   @id @default(uuid())
  content   String
  userId    String
  roomId    String
  user      User     @relation(fields: [userId], references: [id])
  room      Room     @relation(fields: [roomId], references: [id])
  createdAt DateTime @default(now())
}

model Gift {
  id         String   @id @default(uuid())
  type       String   // "champagne", "flower", "diamond", etc.
  creditCost Int
  tlValue    Float
  senderId   String
  receiverId String
  sender     User     @relation("GiftSender", fields: [senderId], references: [id])
  receiver   User     @relation("GiftReceiver", fields: [receiverId], references: [id])
  createdAt  DateTime @default(now())
}

model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  sender     User     @relation("FriendSender", fields: [senderId], references: [id])
  receiver   User     @relation("FriendReceiver", fields: [receiverId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
}

model Block {
  id         String   @id @default(uuid())
  blockerId  String
  blockedId  String
  blocker    User     @relation("Blocker", fields: [blockerId], references: [id])
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([blockerId, blockedId])
}
